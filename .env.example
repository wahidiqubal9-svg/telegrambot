# Your Telegram Bot Token from @BotFather
BOT_TOKEN=123456789:YOUR_BOT_TOKEN_HERE

# The username (e.g., @mychannel) or ID (e.g., -1001234567890) of your public channel
PUBLIC_CHANNEL_ID=@your_public_channel

# The username (e.g., @mygroup) or ID (e.g., -1001234567890) of your public group
PUBLIC_GROUP_ID=@your_public_group

# The ID of your private channel (e.g., -1009876543210). Usually starts with -100 for channels/supergroups.
PRIVATE_CHANNEL_ID=-1001234567890

# Number of successful referrals required to get the private channel link
REQUIRED_REFERRALS=10
